# Morph is BYOK (Bring Your Own Key): the Gemini API key is supplied by the
# user in the UI and stored in the browser only. See SECURITY.md for details.
#
# Supabase — required for auth and note persistence.
# Both values are PUBLIC (safe to ship in the browser bundle). Data isolation
# is enforced by Row Level Security policies in Postgres, not by these keys.
# Copy your project's values from: supabase.com → project → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
